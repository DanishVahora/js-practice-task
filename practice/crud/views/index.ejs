<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <table border="1">
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Email</th>
            <th>Enrollment</th>
            <th>Adress</th>
            <th></th>
            <th></th>
        </tr>
        
        <% students.forEach(stud => { %>
         <tr>
            <td><%= stud.id %></td>
            <td><%= stud.name %></td>
            <td><%= stud.email %></td>
            <td><%= stud.enrollment %></td>
            <td><%= stud.address %></td>
            <td><a href="/edit?id=<%=stud.id%>">Edit</a> </td>
            <td><a style="color: red;" href="/delete?id=<%=stud.id%>">Delete</a></td>
         </tr>
        <% }) %>
    </table>
</body>
</html>