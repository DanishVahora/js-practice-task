<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Candidate Form</title>
    <script src="script.js" defer></script>
</head>

<body>
    <% const navLinks=[ { href: '/index' , label: 'Create Candidate' }, { href: '/users' , label: 'Manage Candidates' }
        ]; const basic={ first_name: 'Danish' , last_name: 'Vahora' , designation: 'PHP Developer' ,
        email: 'danish.vahora@example.com' , mobile_number: '1234567890' , address_1: '123 Main Street' ,
        address_2: 'Apartment 4B' , city: 'Ahmedabad' , state: 'Gujarat' , pincode: '380001' , gender: 'male' ,
        relationship_status: 'married' , dob: '1990-01-01' }; const states=['Gujarat', 'Maharashtra' , 'Delhi' ]; const
        relationships=['single', 'married' , 'divorced' ]; const education={ course: 'Bachelor of Computer Applications'
        , passing_year: 2012, uni_board: 'Gujarat University' , percentage: 75.5 }; const experience={
        company: 'ABC Solutions' , designation: 'Software Engineer' , annual_package: 50000, from: '2012-06-01' ,
        to: '2015-05-31' , reason_to_leave: 'Seeking better opportunities' , ref_contact: 'John Doe' ,
        ref_name: 'Jane Smith' }; const languages=[ { id: 'english' , name: 'English' , checked: true }, { id: 'hindi' ,
        name: 'Hindi' , checked: false }, { id: 'gujarati' , name: 'Gujarati' , checked: false } ]; const technologies=[
        { id: 'php' , name: 'PHP' , checked: true }, { id: 'MySQL' , name: 'MySQL' , checked: false }, { id: 'Laravel' ,
        name: 'Laravel' , checked: false }, { id: 'oracle' , name: 'Oracle' , checked: false } ]; const reference={
        name: 'Jane Smith' , email: 'jane.smith@example.com' , phone: '1234567890' }; const
        jobLocations=['ahemdabad', 'anand' ]; const preferredRoles=['developer', 'manager' , 'analyst' ]; const
        preferences={ expected_salary: '50000.00' , current_salary: '45000.00' , notice_period: 30,
        preferred_role: 'developer' }; %>
        <div style="display: flex; justify-content: center; gap: 16px; margin: 12px 0;">
            <% navLinks.forEach(function (link) { %>
                <a href="<%= link.href %>">
                    <%= link.label %>
                </a>
                <% }) %>
        </div>
        <h1 style="display: flex; justify-content: center;">Form Practice</h1>
        <form onsubmit="return validateForm()" id="candidate_form" method="post">
            <!-- basic details -->
            <div id="basic_details">
                <fieldset>
                    <legend style="font-size: xx-large;">Basic Details :</legend>
                    <br>
                    <label for="fname">First name:</label>
                    <input type="text" id="fname" name="first_name" value="<%= basic.first_name %>">
                    <label style="padding-left: 75px;" for="lname">Last name:</label>
                    <input type="text" id="lname" name="last_name" value="<%= basic.last_name %>">
                    <br>
                    <br>
                    <label for="designation">Designation:</label>
                    <input type="text" id="designation" name="designation" value="<%= basic.designation %>">
                    <br>
                    <br>
                    <br>
                    <br>
                    <label for="email">Email:</label>
                    <input type="email" id="email" name="email" value="<%= basic.email %>">
                    <label style="padding-left: 75px;" for="mobile_number">Mobile Number:</label>
                    <input type="tel" id="mobile_number" name="mobile_number" value="<%= basic.mobile_number %>">
                    <br>
                    <br>
                    <br>
                    <br>
                    <label for="address_1">Address 1:</label>
                    <input type="text" id="address_1" name="address_1" value="<%= basic.address_1 %>">
                    <label style="padding-left: 75px;" for="address_2">Address 2:</label>
                    <input type="text" id="address_2" name="address_2" value="<%= basic.address_2 %>">
                    <br>
                    <br>
                    <label for="city">City:</label>
                    <input type="text" id="city" name="city" value="<%= basic.city %>">
                    <label style="padding-left: 75px;" for="state">State:</label>
                    <select name="state" id="state">
                        <% states.forEach(function (state) { %>
                            <option value="<%= state %>" <%=basic.state===state ? 'selected' : '' %>><%= state %>
                            </option>
                            <% }) %>
                    </select>
                    <label style="padding-left: 75px;" for="pincode">Pincode:</label>
                    <input type="text" id="pincode" name="pincode" value="<%= basic.pincode %>">
                    <br>
                    <br>
                    <br>
                    <br>
                    <label>Gender</label>
                    <input type="radio" id="male" name="gender" value="male" <%=basic.gender==='male' ? 'checked' : ''
                        %>>
                    <label for="male">Male</label>
                    <input type="radio" id="female" name="gender" value="female" <%=basic.gender==='female' ? 'checked'
                        : '' %>>
                    <label for="female">Female</label>

                    <label style="padding-left: 75px;" for="relationship_status">Relationship Status:</label>
                    <select name="relationship_status" id="relationship_status">
                        <% relationships.forEach(function (item) { %>
                            <option value="<%= item %>" <%=basic.relationship_status===item ? 'selected' : '' %>><%=
                                    item.charAt(0).toUpperCase() + item.slice(1) %>
                            </option>
                            <% }) %>
                    </select>
                    <label style="padding-left: 75px;" for="dob">Date of Birth:</label>
                    <input type="date" id="dob" name="dob" value="<%= basic.dob %>">
                </fieldset>
            </div>
            <br><br><br>

            <!-- education -->
            <div id="education_details">
                <fieldset>
                    <legend style="font-size: xx-large;">Education Details :</legend>
                    <div id="education_container">

                        <button type="button" onclick="addEducation()">Add Field</button><button type="button"
                            onclick="removeEducation()">Remove Field</button>
                        <br><br>
                        <label for="course_1">Course:</label>
                        <input type="text" id="course_1" name="course" value="<%= education.course %>"><br><br>
                        <label for="passing_year_1">Passing Year:</label>
                        <input type="number" id="passing_year_1" name="passing_year_1"
                            value="<%= education.passing_year %>">
                        <label style="padding-left: 40px;" for="uni_board_1">University/Board:</label>
                        <input type="text" id="uni_board_1" name="uni_board_1" value="<%= education.uni_board %>">
                        <label style="padding-left: 40px;" for="percentage_1">Percentage:</label>
                        <input type="number" id="percentage_1" name="percentage_1" step="0.01"
                            value="<%= education.percentage %>">
                        <button type="button" id="remove_edu_1" onclick="removeEducationId(1)">X</button>

                    </div>
                </fieldset>
            </div> <br><br><br>

            <!-- experience -->
            <div id="experience">
                <fieldset>
                    <legend style="font-size: xx-large;">Experience Details :
                    </legend>
                    <div id="experience_container">

                        <button type="button" onclick="addExperience()">Add Field</button><button type="button"
                            onclick="removeExperience()">Remove Field</button><br><br>
                        <label for="company_1">Company:</label>
                        <input type="text" id="company_1" name="company_1" value="<%= experience.company %>">
                        <label id="designation_label_1" style="padding-left: 75px;"
                            for="designation_1">Designation:</label>
                        <input type="text" id="designation_1" name="designation_1"
                            value="<%= experience.designation %>">
                        <label id="annual_package_label_1" style="padding-left: 75px;" for="annual_package_1">Annual
                            Package:</label>
                        <input type="number" id="annual_package_1" name="annual_package_1" step="0.01"
                            value="<%= experience.annual_package %>"><br><br>
                        <label id="from_label_1" for="from_1">From:</label>
                        <input type="date" id="from_1" name="from_1" value="<%= experience.from %>">
                        <label id="to_label_1" style="padding-left: 75px;" for="to_1">To:</label>
                        <input type="date" id="to_1" name="to_1" value="<%= experience.to %>">
                        <label id="reason_to_leave_label_1" style="padding-left: 75px;" for="reason_to_leave_1">Reason
                            for
                            Leaving:</label>
                        <input type="text" name="reason_to_leave_1" id="reason_to_leave_1"
                            value="<%= experience.reason_to_leave %>"><br><br>
                        <label id="ref_contact_label_1" for="ref_contact_1">Referral Contact:</label>
                        <input type="text" id="ref_contact_1" name="ref_contact_1"
                            value="<%= experience.ref_contact %>">
                        <label id="ref_name_label_1" style="padding-left: 75px;" for="ref_name_1">Referral Name:</label>
                        <input type="text" id="ref_name_1" name="ref_name_1" value="<%= experience.ref_name %>">
                        <button type="button" id="remove_exp_1" onclick="removeExperienceId(1)">X</button>

                    </div>
                </fieldset>
            </div><br><br><br>

            <!-- languages known -->
            <div id="languages_known">
                <fieldset>
                    <legend style="font-size: xx-large;">Languages Known</legend>
                    <div style="margin-bottom: 10px;">
                        <input type="text" id="language_input" placeholder="Add language"
                            value="<%= languages[0].name %>">
                        <button type="button" onclick="addLanguage()">Add</button>
                    </div>
                    <div id="languages_list">
                        <% languages.forEach(function (lang) { %>
                            <label for="<%= lang.id %>">
                                <%= lang.name %>
                            </label>
                            <input type="checkbox" id="<%= lang.id %>" name="<%= lang.id %>" value="<%= lang.name %>"
                                onclick="checkBox(this)" <%=lang.checked ? 'checked' : '' %>><br>
                            <% }) %>
                                <button type="button" id="remove_lang_1" onclick="removeLanguageId(1)">X</button>
                                <br>
                    </div>
                </fieldset>
            </div><br><br><br>

            <!-- technologies known -->
            <div id="technologies_known">
                <fieldset>
                    <legend style="font-size: xx-large;">Technologies Known</legend>
                    <div style="margin-bottom: 10px;">
                        <input type="text" id="technology_input" placeholder="Add technology"
                            value="<%= technologies[0].name %>">
                        <button type="button" onclick="addTechnology()">Add</button>
                    </div>
                    <div id="technologies_list">
                        <% technologies.forEach(function (tech) { %>
                            <label for="<%= tech.id %>">
                                <%= tech.name %>
                            </label>
                            <input type="checkbox" id="<%= tech.id %>" name="<%= tech.id %>" value="<%= tech.name %>"
                                onclick="radioButton(this)" <%=tech.checked ? 'checked' : '' %>><br>
                            <% }) %>
                    </div>
                </fieldset>
            </div><br><br><br>

            <!-- references contact -->
            <div id="reference_contact">
                <fieldset>
                    <legend style="font-size: xx-large;">Reference Contact</legend>
                    <label for="ref_name">Name:</label>
                    <input type="text" id="ref_name" name="ref_name" value="<%= reference.name %>">
                    <label style="padding-left: 75px;" for="ref_email">Email:</label>
                    <input type="email" id="ref_email" name="ref_email" value="<%= reference.email %>">
                    <label style="padding-left: 75px;" for="ref_phone">Phone Number:</label>
                    <input type="tel" id="ref_phone" name="ref_phone" value="<%= reference.phone %>">
                </fieldset>
            </div><br><br><br>

            <!-- preferences -->
            <div id="preferences">
                <fieldset>
                    <legend style="font-size: xx-large;">Preferences</legend>
                    <label for="job_location">Preferred Job Location:</label>
                    <select name="job_location" id="job_location" multiple>
                        <% jobLocations.forEach(function (location) { %>
                            <option value="<%= location %>">
                                <%= location.charAt(0).toUpperCase() + location.slice(1) %>
                            </option>
                            <% }) %>
                    </select>
                    <label style="padding-left: 75px;" for="expected_salary">Expected Salary:</label>
                    <input type="number" id="expected_salary" name="expected_salary" step="0.01"
                        value="<%= preferences.expected_salary %>">
                    <label style="padding-left: 75px;" for="current_salary">Current Salary:</label>
                    <input type="number" id="current_salary" name="current_salary" step="0.01"
                        value="<%= preferences.current_salary %>"><br><br>
                    <label for="notice_period">Notice Period (in days):</label>
                    <input type="number" id="notice_period" name="notice_period"
                        value="<%= preferences.notice_period %>">
                    <label for="preferred_role">Preferred Role:</label>
                    <select name="preferred_role" id="preferred_role">
                        <% preferredRoles.forEach(function (role) { %>
                            <option value="<%= role %>" <%=preferences.preferred_role===role ? 'selected' : '' %>><%=
                                    role.charAt(0).toUpperCase() + role.slice(1) %>
                            </option>
                            <% }) %>
                    </select>
                </fieldset>
                <button type="submit">submit</button>
            </div>
        </form>
</body>

</html>